# ──────────────────────────────────────────────
# Alchemy — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# ── Application ──────────────────────────────
ALCHEMY_ENV=development
ALCHEMY_DEBUG=true
ALCHEMY_LOG_LEVEL=DEBUG

# ── Mozilla Otari Gateway ────────────────────
# Get your API key from Mozilla Otari dashboard.
# When both are set, the pipeline uses real LLM calls.
# When empty, the pipeline falls back to mock responses.
OTARI_API_KEY=tk_Z3PDce3jzBjNgToNFNc5tJEKQ3ZozAvp
OTARI_BASE_URL=https://api.otari.ai/v1
OTARI_TIMEOUT_MS=30000

# ── OpenAI (via Otari) ──────────────────────
OPENAI_API_KEY=

# ── Groq (OpenAI-compatible) ────────────────
GROQ_API_KEY=
GROQ_BASE_URL=
GROQ_MODEL=
GROQ_TIMEOUT_MS=60000

# ── Ollama (Local 2B) ───────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma:2b

# ── Smallest.ai (Voice STT) ─────────────────
SMALLEST_AI_API_KEY=
SMALLEST_AI_BASE_URL=

# ── Budget ───────────────────────────────────
BUDGET_DAILY_LIMIT_USD=5.00
BUDGET_WARNING_THRESHOLD=0.60
BUDGET_CRITICAL_THRESHOLD=0.85

# ── Semantic Cache ───────────────────────────
CACHE_SIMILARITY_THRESHOLD=0.85
CACHE_DEFAULT_TTL_HOURS=168
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Pinecone Vector DB ───────────────────────
# When both are set, unified memory uses Pinecone for persistent cross-session retrieval.
# When empty, uses local in-memory vector store (fine for single-session CLI use).
PINECONE_API_KEY=
PINECONE_INDEX_NAME=alchemy
PINECONE_NAMESPACE=alchemy

# ── Database ─────────────────────────────────
DATABASE_PATH=data/alchemy.db

# ── Security ─────────────────────────────────
SECURITY_FAIL_OPEN=false
SECURITY_LOG_BLOCKED=true

# ── Context Manager ─────────────────────────
CONTEXT_MAX_CHUNKS_HEALTHY=5
CONTEXT_MAX_CHUNKS_LOW=3
CONTEXT_SUMMARY_MAX_TOKENS=200


# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma:2b
OLLAMA_TIMEOUT_MS=120000

# NVIDIA
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_TIMEOUT_MS=120000

# Groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_MS=120000